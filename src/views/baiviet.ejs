<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title || 'Chi tiết bài viết' %></title>
    <link rel="stylesheet" href="/css/basev2.css">
    <link rel="stylesheet" href="/css/cong_dong.css">
    <script src="https://unpkg.com/lucide@latest"></script>
</head>
<body class="custom-body">
    <%- include('partials/header') %>

    <main class="main-container">
        <div class="post-detail-container" style="max-width: 800px; margin: 2rem auto; padding: 0 1.5rem;">
            <!-- Nút quay lại -->
            <a href="/congdong" class="back-link" style="display: inline-flex; align-items: center; gap: 0.5rem; color: var(--text-muted); text-decoration: none; margin-bottom: 1.5rem; font-weight: 600;">
                <i data-lucide="arrow-left" style="width: 1.25rem; height: 1.25rem;"></i>
                Quay lại cộng đồng
            </a>

            <!-- Bài viết -->
            <div class="post-detail" style="background: white; border-radius: 2rem; padding: 2rem; border: 1px solid var(--border-soft); box-shadow: var(--shadow-lg);">
                <div class="post-detail-header" style="display: flex; align-items: center; gap: 1rem; margin-bottom: 1.5rem;">
                    <div class="post-detail-avatar" style="width: 3.5rem; height: 3.5rem; border-radius: 50%; overflow: hidden;">
                        <img src="<%= post.authorAvatar %>" alt="Avatar" style="width: 100%; height: 100%; object-fit: cover;">
                    </div>
                    <div>
                        <div class="post-detail-author" style="font-weight: 700; font-size: 1.125rem; color: var(--primary);">
                            <%= post.authorName %>
                        </div>
                        <div class="post-detail-time" style="font-size: 0.85rem; color: var(--text-light);">
                            <i data-lucide="calendar" style="width: 0.875rem; height: 0.875rem; display: inline;"></i>
                            <%= post.createdAt %>
                            <span style="margin-left: 1rem;">
                                <i data-lucide="eye" style="width: 0.875rem; height: 0.875rem; display: inline;"></i>
                                <%= post.viewCount %> lượt xem
                            </span>
                        </div>
                    </div>
                </div>

                <h1 class="post-detail-title" style="font-size: 2rem; font-weight: 900; color: var(--primary); margin-bottom: 1.5rem; line-height: 1.3;">
                    <%= post.title %>
                </h1>

                <div class="post-detail-content" style="font-size: 1.1rem; line-height: 1.8; color: var(--text-main);">
                    <p><%= post.content %></p>
                </div>
            </div>

            <!-- Bài viết liên quan -->
            <% if (relatedPosts && relatedPosts.length) { %>
            <section class="related-posts" style="margin-top: 2rem;">
                <h3 style="font-size: 1.25rem; font-weight: 800; color: var(--primary); margin-bottom: 1rem;">
                    Bài viết liên quan
                </h3>
                <div class="related-posts-list" style="display: flex; flex-direction: column; gap: 0.75rem;">
                    <% relatedPosts.forEach(item => { %>
                        <a href="/congdong/bai-viet/<%= item.id %>" style="display: block; padding: 1rem 1.25rem; background: white; border-radius: 1rem; border: 1px solid var(--border-soft); text-decoration: none; transition: all 0.3s ease;">
                            <h4 style="font-weight: 700; color: var(--primary); margin-bottom: 0.25rem;"><%= item.title %></h4>
                            <span style="font-size: 0.85rem; color: var(--text-light);">
                                <%= item.authorName %> • <%= item.createdAt %>
                            </span>
                        </a>
                    <% }); %>
                </div>
            </section>
            <% } %>
        </div>
    </main>

    <%- include('partials/footer') %>
    <script src="/js/trang_chu.js"></script>
</body>
</html>