<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title || 'Tài liệu ôn thi - Đề thi thử' %></title>
    <link rel="stylesheet" href="/css/category_archives.css">
    <link rel="stylesheet" href="/css/base.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@100..900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
</head>
<body>
    <%-include('partials/header')%>
    <div class="welcome" id="welcome-popup">
        <img src="https://tailieuonthi.org/wp-content/uploads/2022/12/cropped-TLOT-1.png.webp" alt="">
        <div class="welcome-content">
            <div class="welcome-header">
                <h3><%= category %></h3>
            </div>
            <div class="welcome-body">
                <p><%= description %></p>
            </div>
        </div>
    </div>
    <div class="title">
        <h3><%= category %></h3>
        <p><%= description %></p>
    </div>
    <div class="container">
        <div class="side-l">
            <div class="searchbox">
                    <input type="text" placeholder="Tìm kiếm ở đây" class="search-input">
                    <button class="search-input-button"><i class="fa-solid fa-magnifying-glass"></i></button>
            </div>
        </div>
        <div class="tests">
            <% testsdata.forEach(test => { %>
                <div class="card">
                    <img src="<%= test.image %>" alt="">
                    <div class="date">
                        <h4><%= test.dateDay %></h4>
                        <p><%= test.dateMonth %></p>
                    </div>
                    <h3><%= test.name %></h3>
                    <p><%= test.excerpt %></p>
                </div>
            <% }) %>
        </div>
    </div>
    <div class="pages">
        <button class="page-btn" id="prev">&lt;</button>
        <button class="page-btn active" id="page1">1</button>
        <button class="page-btn" id="page2">2</button>
        <button class="page-btn" id="page3">3</button>
        <button class="page-btn" id="page4">4</button>
        <span>...</span>
        <button class="page-btn" id="next">&gt;</button>
    </div>
    <%- include('partials/footer')%>
    <script src="/js/home.js"></script>
    <script src="/js/pagination.js"></script>
</body>
</html>
