<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title || 'DocuStudy - Trang chủ' %></title>
    <link rel="stylesheet" href="css/basev2.css">
    <link rel="stylesheet" href="css/trang_chu_v2.css">
    <link rel="stylesheet" href="css/search.css">
    <script src="https://unpkg.com/lucide@latest"></script>
    <script src="js/search.js" defer></script>
</head> 
<body class="custom-body">
    <%-include('partials/header')%>
    <main>
        <!-- HERO SECTION (giữ nguyên - tĩnh) -->
        <section class="hero-section">
            <div class="container">
            <div class="hero-content">
                <h1 class="hero-title">
                Nơi khởi đầu <br />
                <span class="hero-highlight">tri thức</span> mới.
                </h1>
                <p class="hero-description">
                Hệ thống chia sẻ tài liệu học tập tối giản, thông minh và hiệu quả dành riêng cho học sinh Việt Nam.
                </p>
                <div class="search-wrapper">
                <div class="search-icon"><i data-lucide="search" class="search-icon-svg"></i></div>
                <input type="text" class="search-input" placeholder="Tìm tên đề thi, tài liệu hoặc môn học..." />
                <div class="search-btn-wrapper"><button class="search-btn">Tìm kiếm</button></div>
                </div>
                <div class="trending-wrapper">
                <span class="trending-label">Xu hướng:</span>
                <button class="trending-btn">ĐGNL 2026</button>
                <button class="trending-btn">TSA Bách Khoa</button>
                <button class="trending-btn">Toán 12</button>
                </div>
            </div>
            <img src="img/hero.jpg" alt="hero-img" class="hero-image">
            </div>
        </section>

            <!-- 1. Các kỳ thi có tabs (HSA, TSA, V-ACT) -->
            <% if (examSections && examSections.length) { %>
                <% examSections.forEach(section => { %>
                <%- include('partials/exam-section.ejs', { section: section }) %>
                <% }); %>
            <% } %>

            <!-- 2. Các grid đơn giản (SPT, THPTQG) -->
            <% if (simpleGridSections && simpleGridSections.length && simpleGridCards && simpleGridCards.length) { %>
                <% simpleGridSections.forEach((section, idx) => { %>
                <%- include('partials/simple-grid-section.ejs', { 
                    section: section, 
                    cards: simpleGridCards[idx] 
                }) %>
                <% }); %>
            <% } %>

            <!-- 3. Các khối lớp 10, 11, 12 -->
            <% if (gradeSections && gradeSections.length) { %>
                <% gradeSections.forEach(gradeSec => { %>
                <section class="<%= gradeSec.wrapperClass %>">
                    <div class="container">
                    <div class="<%= gradeSec.innerClass %>">
                        <div class="<%= gradeSec.headerClass %>">
                        <h2 class="section-title"><%= gradeSec.title %></h2>
                        <div class="tab-bar">
                            <div class="tab-list">
                            <% gradeSec.subjects.forEach((subject, idx) => { %>
                                <button class="tab-btn <%= idx === 0 ? 'active' : '' %>" data-target="<%= subject.targetId %>">
                                <%= subject.name %>
                                </button>
                            <% }); %>
                            </div>
                            <div class="tab-divider"></div>
                            <div class="tab-pagination">
                            <button class="btn-prev-page"><i data-lucide="chevron-left"></i></button>
                            <button class="btn-next-page"><i data-lucide="chevron-right"></i></button>
                            </div>
                        </div>
                        </div>
                        <div class="tab-content-wrapper">
                        <% gradeSec.subjects.forEach((subject, idx) => { %>
                            <div class="tab-content <%= idx === 0 ? 'active' : '' %>" id="<%= subject.targetId %>">
                            <%- include('partials/tab-content.ejs', { tabData: subject.content }) %>
                            </div>
                        <% }); %>
                        </div>
                    </div>
                    </div>
                </section>
                <% }); %>
            <% } %>

        <!-- TIN TỨC & SỰ KIỆN (có thể động) -->
        <section class="news-section">
            <div class="container">
            <div class="news-header">
                <h2 class="section-title">Tin tức & Sự kiện</h2>
                <p class="news-subtitle">Cập nhật mới nhất về kỳ thi, tài liệu và hoạt động của DocuStudy</p>
            </div>
            <div class="news-grid">
                <!-- Bài viết nổi bật bên trái -->
                <div class="news-main">
                <div class="news-main-image">
                    <img src="<%= featuredNews.image %>" alt="Tin tức nổi bật" />
                </div>
                <div class="news-main-content">
                    <span class="news-badge">Mới nhất</span>
                    <h3 class="news-main-title"><%= featuredNews.title %></h3>
                    <p class="news-main-desc"><%= featuredNews.description %></p>
                    <div class="news-main-footer">
                    <span><i data-lucide="calendar"></i> <%= featuredNews.date %></span>
                    <a href="<%= featuredNews.link %>" class="news-read-more">Đọc thêm <i data-lucide="chevron-right"></i></a>
                    </div>
                </div>
                </div>

                <!-- Danh sách bài viết bên phải -->
                <div class="news-side">
                <% if (newsList && newsList.length) { %>
                    <% newsList.forEach(item => { %>
                    <a href="<%= item.link %>" class="news-item">
                        <div class="news-item-image"><img src="<%= item.image %>" alt="Thumb" /></div>
                        <div class="news-item-body">
                        <h4 class="news-item-title"><%= item.title %></h4>
                        <span class="news-item-date"><%= item.date %></span>
                        </div>
                    </a>
                    <% }); %>
                <% } %>
                </div>
            </div>
            </div>
        </section>

        <!-- CTA SECTION (tĩnh) -->
        <section class="cta-section">
            <div class="cta-container">
            <div class="cta-content">
                <h2 class="cta-title">
                Bạn có tài liệu hay? <br />
                <span class="cta-highlight">Chia sẻ ngay</span> cùng cộng đồng.
                </h2>
                <p class="cta-description">
                Mỗi tài liệu bạn đóng góp đều giúp ích cho hàng ngàn học sinh khác trên khắp cả nước. Tham gia cùng chúng tôi ngay hôm nay!
                </p>
                <div class="cta-buttons">
                <button class="cta-btn-primary" onclick="openUserUploadModal()">Đăng tải tài liệu</button>
                <button class="cta-btn-secondary">Tìm hiểu thêm</button>
                </div>
            </div>
            <div class="cta-bg-effect cta-bg-orange"></div>
            <div class="cta-bg-effect cta-bg-blue"></div>
            </div>
        </section>
        </main>
    <%- include('partials/footer')%>
 
    <!-- Modal Tải Lên Tài Liệu Cho User -->
    <div id="userUploadModal" class="auth-page-container" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: 2000; background: rgba(15, 23, 42, 0.7); backdrop-filter: blur(8px);">
        <div class="auth-card" style="max-width: 500px; padding: 40px; border-radius: 32px;">
            <div class="auth-icon-box" style="background: #eff6ff; color: #3b82f6;">
                <i data-lucide="upload-cloud" style="width: 32px; height: 32px;"></i>
            </div>
            <h2 style="margin-top:0; font-size: 1.75rem; font-weight: 800;">Chia sẻ tri thức</h2>
            <p style="font-size: 1rem; color: #64748b; margin-bottom: 32px;">Mỗi tài liệu bạn đóng góp là một món quà cho cộng đồng.</p>
            
            <div id="uploadStatus" class="auth-status-msg"></div>

            <form id="userUploadForm" class="auth-form">
                <div class="auth-input-group">
                    <label>Tiêu đề tài liệu</label>
                    <div class="auth-input-wrapper">
                        <i data-lucide="type"></i>
                        <input type="text" name="title" id="uploadTitle" placeholder="VD: Đề thi thử Toán THPTQG 2026..." required>
                    </div>
                </div>

                <div class="auth-input-group">
                    <label>Danh mục</label>
                    <div class="auth-input-wrapper">
                        <i data-lucide="layers"></i>
                        <select name="subcategory_id" id="uploadSubId" required style="width: 100%; padding: 14px 16px 14px 48px; border: 2px solid #f1f5f9; border-radius: 14px; font-size: 1rem; appearance: none; background: #f8fafc;">
                            <option value="">Chọn danh mục phù hợp...</option>
                            <% allSubcategories.forEach(sub => { %>
                                <option value="<%= sub.id %>"><%= sub.name %></option>
                            <% }) %>
                        </select>
                    </div>
                </div>

                <div class="auth-input-group">
                    <label>Chọn tệp tin</label>
                    <div class="auth-input-wrapper" style="border: 2px dashed #e2e8f0; border-radius: 14px; padding: 20px; text-align: center; background: #f8fafc; transition: all 0.3s;">
                        <input type="file" name="file" id="uploadFile" required style="cursor: pointer;">
                        <p style="font-size: 0.8rem; color: #94a3b8; margin-top: 8px;">Hỗ trợ: PDF, DOCX, ZIP (Tối đa 10MB)</p>
                    </div>
                </div>

                <button type="submit" class="auth-submit-btn" id="uploadSubmitBtn" style="background: #f97316;">
                    <span>Bắt đầu tải lên ngay</span>
                    <i data-lucide="send" style="width: 18px; height: 18px;"></i>
                </button>
                <button type="button" class="auth-link" style="width:100%; border:none; background:none; margin-top:16px; cursor:pointer;" onclick="closeUserUploadModal()">Lúc khác tôi sẽ chia sẻ</button>
            </form>
        </div>
    </div>

    <script src="js/trang_chu.js"></script>
    <script>
        lucide.createIcons();

        function openUserUploadModal() {
            // Kiểm tra đăng nhập qua biến user được inject từ server.js
            <% if (!user) { %>
                alert('Vui lòng đăng nhập để thực hiện chức năng này!');
                return;
            <% } %>
            document.getElementById('userUploadModal').style.display = 'flex';
        }

        function closeUserUploadModal() {
            document.getElementById('userUploadModal').style.display = 'none';
        }

        document.getElementById('userUploadForm').onsubmit = async (e) => {
            e.preventDefault();
            const formData = new FormData();
            formData.append('title', document.getElementById('uploadTitle').value);
            formData.append('subcategory_id', document.getElementById('uploadSubId').value);
            formData.append('file', document.getElementById('uploadFile').files[0]);

            const status = document.getElementById('uploadStatus');
            const btn = document.getElementById('uploadSubmitBtn');

            btn.disabled = true;
            btn.innerHTML = 'Đang tải lên...';
            status.style.display = 'none';

            try {
                const res = await fetch('/auth/upload-document', {
                    method: 'POST',
                    body: formData
                });
                const data = await res.json();

                if (data.success) {
                    status.className = 'auth-status-msg success';
                    status.innerHTML = data.message;
                    status.style.display = 'block';
                    document.getElementById('userUploadForm').style.display = 'none';
                    setTimeout(() => location.reload(), 3000);
                } else {
                    status.className = 'auth-status-msg error';
                    status.innerHTML = data.message;
                    status.style.display = 'block';
                    btn.disabled = false;
                    btn.innerHTML = 'Bắt đầu tải lên ngay';
                }
            } catch (err) {
                console.error(err);
                status.className = 'auth-status-msg error';
                status.innerHTML = 'Lỗi hệ thống khi tải lên!';
                status.style.display = 'block';
                btn.disabled = false;
                btn.innerHTML = 'Bắt đầu tải lên ngay';
            }
            lucide.createIcons();
        };
    </script>
</body>
</html>