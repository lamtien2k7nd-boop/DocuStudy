<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - DocuStudy</title>
    <link rel="stylesheet" href="/css/auth.css">
    <link rel="stylesheet" href="/css/basev2.css">
    <script src="https://unpkg.com/lucide@latest"></script>
</head>
<body>
    <%- include('../partials/header') %>

    <main class="auth-page-container">
        <div class="auth-card">
            <div class="auth-icon-box">
                <i data-lucide="shield-check" style="width: 36px; height: 36px;"></i>
            </div>
            <h1>Đặt lại mật khẩu</h1>
            <p>Hãy tạo một mật khẩu mới mạnh mẽ để bảo vệ tài khoản của bạn.</p>

            <div id="statusMessage" class="auth-status-msg"></div>

            <form id="resetForm" class="auth-form">
                <div class="auth-input-group">
                    <label for="password">Mật khẩu mới</label>
                    <div class="auth-input-wrapper">
                        <i data-lucide="lock"></i>
                        <input type="password" id="password" placeholder="••••••••" required minlength="6">
                    </div>
                </div>
                <div class="auth-input-group">
                    <label for="confirmPassword">Xác nhận mật khẩu</label>
                    <div class="auth-input-wrapper">
                        <i data-lucide="check-circle"></i>
                        <input type="password" id="confirmPassword" placeholder="••••••••" required minlength="6">
                    </div>
                </div>
                <button type="submit" class="auth-submit-btn" id="submitBtn">
                    <span>Cập nhật mật khẩu</span>
                    <i data-lucide="check" style="width: 18px; height: 18px;"></i>
                </button>
            </form>
        </div>
    </main>

    <%- include('../partials/footer') %>

    <script>
        lucide.createIcons();

        document.getElementById('resetForm').onsubmit = async (e) => {
            e.preventDefault();
            const password = document.getElementById('password').value;
            const confirmPassword = document.getElementById('confirmPassword').value;
            const statusMessage = document.getElementById('statusMessage');
            const submitBtn = document.getElementById('submitBtn');

            if (password !== confirmPassword) {
                statusMessage.className = 'auth-status-msg error';
                statusMessage.innerHTML = 'Mật khẩu xác nhận không khớp!';
                statusMessage.style.display = 'block';
                return;
            }

            submitBtn.disabled = true;
            const originalBtnContent = submitBtn.innerHTML;
            submitBtn.innerHTML = '<span>Đang cập nhật...</span><i data-lucide="loader-2" class="animate-spin" style="width: 18px; height: 18px;"></i>';
            lucide.createIcons();

            try {
                const res = await fetch(window.location.pathname, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ password, confirmPassword })
                });

                const data = await res.json();

                if (data.success) {
                    statusMessage.className = 'auth-status-msg success';
                    statusMessage.innerHTML = data.message;
                    document.getElementById('resetForm').style.display = 'none';
                    document.querySelector('.auth-card p').innerHTML = 'Bạn sẽ được chuyển hướng về trang chủ trong giây lát.';
                    setTimeout(() => {
                        window.location.href = '/';
                    }, 3000);
                } else {
                    statusMessage.className = 'auth-status-msg error';
                    statusMessage.innerHTML = data.message;
                    statusMessage.style.display = 'block';
                    submitBtn.disabled = false;
                    submitBtn.innerHTML = originalBtnContent;
                }
            } catch (err) {
                console.error(err);
                statusMessage.className = 'auth-status-msg error';
                statusMessage.innerHTML = 'Có lỗi xảy ra. Vui lòng thử lại sau.';
                statusMessage.style.display = 'block';
                submitBtn.disabled = false;
                submitBtn.innerHTML = originalBtnContent;
            }
            lucide.createIcons();
        };

        // Thêm animation CSS cho loader-2
        const style = document.createElement('style');
        style.innerHTML = `
            .animate-spin { animation: spin 1s linear infinite; }
            @keyframes spin { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
        `;
        document.head.appendChild(style);
    </script>
</body>
</html>
