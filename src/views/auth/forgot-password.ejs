<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - DocuStudy</title>
    <link rel="stylesheet" href="/css/auth.css">
    <link rel="stylesheet" href="/css/basev2.css">
    <script src="https://unpkg.com/lucide@latest"></script>
</head>
<body>
    <%- include('../partials/header') %>

    <main class="auth-page-container">
        <div class="auth-card">
            <div class="auth-icon-box">
                <i data-lucide="key-round" style="width: 36px; height: 36px;"></i>
            </div>
            <h1>Quên mật khẩu?</h1>
            <p>Nhập email của bạn và chúng tôi sẽ gửi liên kết để đặt lại mật khẩu trong giây lát.</p>

            <div id="statusMessage" class="auth-status-msg"></div>

            <form id="forgotForm" class="auth-form">
                <div class="auth-input-group">
                    <label for="email">Địa chỉ Email</label>
                    <div class="auth-input-wrapper">
                        <i data-lucide="mail"></i>
                        <input type="email" id="email" placeholder="name@example.com" required>
                    </div>
                </div>
                <button type="submit" class="auth-submit-btn" id="submitBtn">
                    <span>Gửi liên kết khôi phục</span>
                    <i data-lucide="send" style="width: 18px; height: 18px;"></i>
                </button>
            </form>

            <div class="auth-footer-links">
                <a href="/" class="auth-link">
                    <i data-lucide="arrow-left" style="width: 16px; height: 16px;"></i>
                    Quay lại trang chủ
                </a>
            </div>
        </div>
    </main>

    <%- include('../partials/footer') %>

    <script>
        lucide.createIcons();

        document.getElementById('forgotForm').onsubmit = async (e) => {
            e.preventDefault();
            const email = document.getElementById('email').value;
            const submitBtn = document.getElementById('submitBtn');
            const statusMessage = document.getElementById('statusMessage');

            submitBtn.disabled = true;
            const originalBtnContent = submitBtn.innerHTML;
            submitBtn.innerHTML = '<span>Đang gửi...</span><i data-lucide="loader-2" class="animate-spin" style="width: 18px; height: 18px;"></i>';
            lucide.createIcons();
            
            statusMessage.style.display = 'none';

            try {
                const res = await fetch('/auth/forgot-password', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ email })
                });

                const data = await res.json();
                
                if (data.success) {
                    statusMessage.className = 'auth-status-msg success';
                    statusMessage.innerHTML = data.message;
                    document.getElementById('forgotForm').style.display = 'none';
                    document.querySelector('.auth-card p').innerHTML = 'Vui lòng kiểm tra hộp thư đến của bạn để tiếp tục.';
                } else {
                    statusMessage.className = 'auth-status-msg error';
                    statusMessage.innerHTML = data.message;
                    submitBtn.disabled = false;
                    submitBtn.innerHTML = originalBtnContent;
                }
                statusMessage.style.display = 'block';
            } catch (err) {
                console.error(err);
                statusMessage.className = 'auth-status-msg error';
                statusMessage.innerHTML = 'Có lỗi xảy ra. Vui lòng thử lại sau.';
                statusMessage.style.display = 'block';
                submitBtn.disabled = false;
                submitBtn.innerHTML = originalBtnContent;
            }
            lucide.createIcons();
        };

        // Thêm animation CSS cho loader-2
        const style = document.createElement('style');
        style.innerHTML = `
            .animate-spin { animation: spin 1s linear infinite; }
            @keyframes spin { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
        `;
        document.head.appendChild(style);
    </script>
</body>
</html>
