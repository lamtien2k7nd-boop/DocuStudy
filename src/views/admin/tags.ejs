<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Quản lý Tag - Admin</title>
    <link rel="stylesheet" href="/css/basev2.css">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
    <script src="https://unpkg.com/lucide@latest"></script>
    <style>
        :root {
            --sidebar-width: 260px;
            --primary: #6366f1;
            --primary-light: #e0e7ff;
            --bg-body: #f8fafc;
        }

        body { font-family: 'Plus Jakarta Sans', sans-serif; background-color: var(--bg-body); margin: 0; display: flex; }

        .sidebar { width: var(--sidebar-width); background: #ffffff; height: 100vh; border-right: 1px solid #e2e8f0; position: fixed; padding: 1.5rem; display: flex; flex-direction: column; }
        .logo { font-size: 1.25rem; font-weight: 700; color: var(--primary); margin-bottom: 2rem; display: flex; align-items: center; gap: 0.75rem; }
        .nav-link { display: flex; align-items: center; gap: 0.75rem; padding: 0.75rem 1rem; color: #64748b; text-decoration: none; border-radius: 0.5rem; transition: all 0.2s; margin-bottom: 0.5rem; }
        .nav-link:hover, .nav-link.active { background: #f1f5f9; color: var(--primary); }

        .main-content { margin-left: var(--sidebar-width); flex: 1; padding: 2rem; }
        .header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem; }
        
        .doc-card {
            background: #fff; padding: 1.5rem; border-radius: 1rem; margin-bottom: 1rem;
            border: 1px solid #f1f5f9; box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.1);
        }
        .doc-header { display: flex; justify-content: space-between; align-items: center; }
        .doc-title { font-weight: 700; font-size: 1.1rem; color: #1e293b; }
        
        .tag-list { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-top: 1rem; }
        .tag-badge {
            padding: 4px 12px; background: #f1f5f9; border-radius: 9999px; font-size: 0.8rem;
            display: flex; align-items: center; gap: 6px; color: #475569;
        }
        .tag-badge.category { background: #fee2e2; color: #ef4444; }
        .tag-badge.subcategory { background: #eff6ff; color: #3b82f6; }
        .btn-del-tag { border: none; background: none; color: #94a3b8; cursor: pointer; padding: 0; display: flex; }
        .btn-del-tag:hover { color: #ef4444; }

        .btn-add-tag {
            padding: 8px 16px; background: var(--primary); color: #fff;
            border: none; border-radius: 8px; font-weight: 600; cursor: pointer;
            font-size: 0.85rem;
        }

        /* Modal simple */
        .modal-overlay { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); z-index: 100; align-items: center; justify-content: center; }
        .modal-overlay.active { display: flex; }
        .modal-box { background: #fff; padding: 2rem; border-radius: 1rem; width: 400px; }
    </style>
</head>
<body>
    <aside class="sidebar">
        <div class="logo"><i data-lucide="layout-dashboard"></i> DS Admin</div>
        <nav>
            <a href="/admin/dashboard" class="nav-link"><i data-lucide="home"></i> Dashboard</a>
            <a href="/admin/documents" class="nav-link"><i data-lucide="file-text"></i> Tài liệu</a>
            <a href="/admin/structure" class="nav-link"><i data-lucide="database"></i> Cấu trúc đề thi</a>
            <a href="/admin/tags" class="nav-link active"><i data-lucide="tag"></i> Quản lý Tag</a>
            <a href="/admin/logout" class="nav-link"><i data-lucide="log-out"></i> Đăng xuất</a>
        </nav>
    </aside>

    <main class="main-content">
        <header class="header">
            <h1>Quản lý Tag tài liệu</h1>
            <p style="color: #64748b;">Gán các tag (từ Categories/Subcategories) cho tài liệu để tìm kiếm dễ dàng hơn.</p>
        </header>

        <% documents.forEach(doc => { %>
            <div class="doc-card">
                <div class="doc-header">
                    <div class="doc-title"><%= doc.title %></div>
                    <button class="btn-add-tag" onclick="openAddTagModal(<%= doc.id %>, '<%= doc.title.replace(/'/g, "\\'") %>')">Thêm Tag</button>
                </div>
                <div class="tag-list">
                    <% if (doc.tags && doc.tags.length > 0) { %>
                        <% doc.tags.forEach(tag => { %>
                            <div class="tag-badge <%= tag.type %>">
                                <span><%= tag.label %></span>
                                <form action="/admin/tags/delete" method="POST" style="display:inline;">
                                    <input type="hidden" name="tag_id" value="<%= tag.id %>">
                                    <button type="submit" class="btn-del-tag"><i data-lucide="x" style="width:14px;"></i></button>
                                </form>
                            </div>
                        <% }) %>
                    <% } else { %>
                        <span style="color: #cbd5e1; font-style: italic; font-size: 0.85rem;">Chưa có tag nào</span>
                    <% } %>
                </div>
            </div>
        <% }) %>
    </main>

    <div class="modal-overlay" id="addTagModal">
        <div class="modal-box">
            <h3 id="modalTitle">Thêm Tag</h3>
            <form action="/admin/tags/add" method="POST">
                <input type="hidden" name="document_id" id="modalDocId">
                <div style="margin-bottom: 1rem;">
                    <label style="display:block; margin-bottom: 0.5rem; font-size: 0.85rem; font-weight: 600;">Chọn Tag từ hệ thống</label>
                    <select name="tag_data" required style="width:100%; padding: 8px; border-radius: 8px; border: 1px solid #e2e8f0;">
                        <optgroup label="Categories">
                            <% categories.forEach(cat => { %>
                                <option value="category:<%= cat.slug %>:<%= cat.name %>"><%= cat.name %></option>
                            <% }) %>
                        </optgroup>
                        <optgroup label="Subcategories">
                            <% subcategories.forEach(sub => { %>
                                <option value="subcategory:<%= sub.target_id %>:<%= sub.name %>"><%= sub.name %></option>
                            <% }) %>
                        </optgroup>
                    </select>
                </div>
                <div style="display:flex; justify-content: flex-end; gap: 0.5rem;">
                    <button type="button" onclick="closeModal()" style="padding: 8px 16px; border:none; border-radius: 8px; cursor:pointer;">Hủy</button>
                    <button type="submit" style="padding: 8px 16px; background: var(--primary); color:#fff; border:none; border-radius: 8px; cursor:pointer;">Thêm</button>
                </div>
            </form>
        </div>
    </div>

    <script>
        lucide.createIcons();
        function openAddTagModal(id, title) {
            document.getElementById('modalDocId').value = id;
            document.getElementById('modalTitle').innerText = 'Thêm Tag cho: ' + title;
            document.getElementById('addTagModal').classList.add('active');
        }
        function closeModal() {
            document.getElementById('addTagModal').classList.remove('active');
        }
    </script>
</body>
</html>
